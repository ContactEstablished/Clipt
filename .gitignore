# ============================================================
# Clipt — .gitignore
# .NET 9 WPF / SQLite / Velopack
# ============================================================

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
[Pp]ublish/
[Pp]ublishProfiles/
[Aa]rtifacts/
[Cc]overage/
[Tt]est[Rr]esults/
*.lastbuildstate
*.unsuccessfulbuild

# ------------------------------------------------------------
# .NET / MSBuild
# ------------------------------------------------------------
project.lock.json
project.fragment.lock.json
artifacts/
*.binlog
*.tlog
*.cache
*.lastcodeanalysissucceeded
*.VC.db
*.VC.VC.opendb

# Restore output
.dotnet/
.dotnet-home/
.appdata/
*.nuget.props
*.nuget.targets

# Source generators output (CommunityToolkit.Mvvm generates these)
[Gg]enerated/
*.g.cs
*.g.i.cs
# Note: do NOT exclude *.Designer.cs — those are checked-in WPF designer files

# ------------------------------------------------------------
# NuGet
# ------------------------------------------------------------
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.cache
.nuget/
nuget.exe

# ------------------------------------------------------------

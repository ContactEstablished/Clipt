# ------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.psess
*.vsp
*.vspx
*.sap
*.VisualState.xml
TestResult.xml
nunit-*.xml
*.tmp_proj
*_wpftmp.csproj

# Visual Studio cache files
ipch/
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio code coverage
*.coverage
*.coveragexml

# ------------------------------------------------------------
# JetBrains Rider / ReSharper
# ------------------------------------------------------------
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ------------------------------------------------------------
# VS Code
# ------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.code-workspace

# ------------------------------------------------------------
# Application secrets & local config
# ------------------------------------------------------------
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
secrets.json
.env
.env.*
!.env.example
*.pfx
*.snk
local.settings.json

# ------------------------------------------------------------
# Clipt-specific runtime artifacts
# ------------------------------------------------------------
# Never commit a real clipboard database
clipt.db
clipt.db-journal
clipt.db-wal
clipt.db-shm
*.clipt
*.clipt.json.enc

# Never commit user-exported backup files (encrypted or not)
exports/
backups/

# Local dev clipboard data folder (mirrors %LOCALAPPDATA%\Clipt during dev)
.clipt-data/

# ------------------------------------------------------------
# Velopack / installer artifacts
# ------------------------------------------------------------
ReleasesDir/
[Pp]ackages/[Pp]ublish/
*.exe.config
*.application
*.appxbundle
*.appxsym
*.appxupload
*.msi
*.msix
*.msixbundle

# Code-signing certificates and keys — NEVER commit
*.pfx
*.p12
*.cer
*.crt
*.key
codesign/
signing/

# ------------------------------------------------------------
# WPF / WinUI build artifacts
# ------------------------------------------------------------
*.baml
*.g.resources
*.exe.manifest
*.application
*.deploy

# ------------------------------------------------------------
# Logs and diagnostics
# ------------------------------------------------------------
*.log
*.tlog
serilog-*.txt
nlog*.config.transform
Crashes/
*.dmp
*.mdmp
hs_err_pid*.log

# ------------------------------------------------------------
# Test artifacts
# ------------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
*.opencover.xml
TestResults/
.coverlet/
coverage/
coverage.json
coverage.cobertura.xml

# StyleCop / analyzers
StyleCopReport.xml

# ------------------------------------------------------------
# OS-specific
# ------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# macOS (in case you're ever on a different machine)
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------
# Tools and editors
# ------------------------------------------------------------
*.swp
*.swo
*~
.fake/

# ------------------------------------------------------------
# Documentation generation
# ------------------------------------------------------------
_site/
DocFx/
docs/_site/
docs/api/

# ------------------------------------------------------------
# Node (only if you add any frontend tooling later — README screenshots, etc.)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ------------------------------------------------------------
# Frontend assets (if README site or marketing page is added)
# ------------------------------------------------------------
.next/
.nuxt/
.output/
.cache/

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.bak
*.orig
*.rej
*.tmp
*.temp
*.old

.claude/worktrees/pedantic-cartwright-dbaacb

<Window x:Class="Clipt.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Clipt.App.Controls"
        Title="Settings"
        Width="640"
        Height="460"
        MinWidth="520"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Clipt.Brush.Background}"
        FontFamily="{StaticResource Clipt.Font.Ui}"
        FontSize="13">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Margin="0,0,0,12"
                    Padding="0"
                    Background="{DynamicResource Clipt.Brush.Surface}"
                    BorderBrush="{DynamicResource Clipt.Brush.Border}">
            <TabControl.Resources>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.Text}" />
                    <Setter Property="FontFamily" Value="{StaticResource Clipt.Font.Ui}" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Padding" Value="14,8" />
                    <Setter Property="Margin" Value="0,0,4,0" />
                    <Setter Property="MinHeight" Value="34" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Border x:Name="TabBorder"
                                        Background="{DynamicResource Clipt.Brush.SurfaceAlt}"
                                        BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="6,6,0,0"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Clipt.Brush.AccentSoft}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.Text}" />
                                        <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Clipt.Brush.Surface}" />
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Clipt.Brush.Accent}" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.TextMuted}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </TabControl.Resources>

            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Paste" />
                        <CheckBox Content="Auto-paste on Enter when another window was focused"
                                  Foreground="{DynamicResource Clipt.Brush.Text}"
                                  IsChecked="{Binding AutoPasteOnEnter}" />
                        <CheckBox Margin="0,10,0,0"
                                  Content="Restore previous clipboard after paste"
                                  Foreground="{DynamicResource Clipt.Brush.Text}"
                                  IsChecked="{Binding RestorePreviousClipboardAfterPaste}"
                                  ToolTip="After auto-paste, put the clipboard back the way it was before Clipt wrote the selected item." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="History">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Retention" />
                        <TextBlock Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="Pinned items are never pruned. The two limits below run at startup and after every capture." />
                        <TextBlock Margin="0,14,0,6"
                                   Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   Text="Max history items" />
                        <TextBox Width="160"
                                 HorizontalAlignment="Left"
                                 Foreground="{DynamicResource Clipt.Brush.Text}"
                                 Background="#1C1C20"
                                 BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 CaretBrush="{DynamicResource Clipt.Brush.Accent}"
                                 Text="{Binding MaxHistoryItemsText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,14,0,6"
                                   Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   Text="Auto-prune after (days)" />
                        <TextBox Width="160"
                                 HorizontalAlignment="Left"
                                 Foreground="{DynamicResource Clipt.Brush.Text}"
                                 Background="#1C1C20"
                                 BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 CaretBrush="{DynamicResource Clipt.Brush.Accent}"
                                 Text="{Binding AutoPruneAfterDaysText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Leave blank or 0 to disable. Items older than this are removed automatically." />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                                   FontSize="12"
                                   Text="Leave blank or 0 to keep history forever." />

                        <Separator Margin="0,18,0,14" />

                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Per-clip size limit" />
                        <TextBlock Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="Skip clipboard items larger than this. Images use their estimated decoded size." />
                        <TextBlock Margin="0,14,0,6"
                                   Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   Text="Max clip size (MB)" />
                        <TextBox Width="160"
                                 HorizontalAlignment="Left"
                                 Foreground="{DynamicResource Clipt.Brush.Text}"
                                 Background="#1C1C20"
                                 BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 CaretBrush="{DynamicResource Clipt.Brush.Accent}"
                                 Text="{Binding MaxClipSizeMegabytesText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="0 disables the cap. Decimals allowed (e.g. 0.5)." />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                                   FontSize="12"
                                   Text="0 disables the cap. Decimals allowed (e.g. 0.5)." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Privacy">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Capture filtering" />
                        <TextBlock Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Text="One entry per line. Names match the source app title; paths prefix-match. Patterns match title, preview, or body (prefix with regex: for regex)." />
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   Text="Ignored app names" />
                        <TextBox AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="72"
                                 Foreground="{DynamicResource Clipt.Brush.Text}"
                                 Background="#1C1C20"
                                 BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                 BorderThickness="1"
                                 Padding="8"
                                 CaretBrush="{DynamicResource Clipt.Brush.Accent}"
                                 FontFamily="{StaticResource Clipt.Font.Mono}"
                                 FontSize="12"
                                 Text="{Binding IgnoredAppNamesText, UpdateSourceTrigger=PropertyChanged}" />
                        <Grid Margin="0,12,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                       Text="Ignored app paths" />
                            <Button Grid.Column="1"
                                    Padding="10,4"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Foreground="{DynamicResource Clipt.Brush.Accent}"
                                    Cursor="Hand"
                                    Content="Browse…"
                                    Command="{Binding BrowseForIgnoredAppPathCommand}"
                                    ToolTip="Pick an executable to add its path to the list." />
                        </Grid>
                        <TextBox AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="72"
                                 Foreground="{DynamicResource Clipt.Brush.Text}"
                                 Background="#1C1C20"
                                 BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                 BorderThickness="1"
                                 Padding="8"
                                 CaretBrush="{DynamicResource Clipt.Brush.Accent}"
                                 FontFamily="{StaticResource Clipt.Font.Mono}"
                                 FontSize="12"
                                 Text="{Binding IgnoredAppPathsText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,12,0,6"
                                   Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   Text="Ignored patterns" />
                        <TextBox AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="72"
                                 Foreground="{DynamicResource Clipt.Brush.Text}"
                                 Background="#1C1C20"
                                 BorderBrush="{DynamicResource Clipt.Brush.Border}"
                                 BorderThickness="1"
                                 Padding="8"
                                 CaretBrush="{DynamicResource Clipt.Brush.Accent}"
                                 FontFamily="{StaticResource Clipt.Font.Mono}"
                                 FontSize="12"
                                 Text="{Binding IgnoredPatternsText, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,14,0,0"
                                  Content="Honor Clipboard Viewer ignore flag"
                                  Foreground="{DynamicResource Clipt.Brush.Text}"
                                  IsChecked="{Binding HonorClipboardViewerIgnore}"
                                  ToolTip="Skip captures from apps that mark clipboard contents as hidden from clipboard managers." />
                        <TextBlock Margin="0,16,0,0"
                                   Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Saved privacy lists apply immediately after Save." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Hotkey">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Global shortcut" />
                        <TextBlock Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Text="Click the field, then press modifiers (Ctrl, Alt, Shift, Win) plus one key." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <controls:HotkeyCaptureControl
                                Grid.Column="0"
                                HotkeyText="{Binding OpenHotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Padding="10,6"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Foreground="{DynamicResource Clipt.Brush.Accent}"
                                    Cursor="Hand"
                                    Content="Reset"
                                    Command="{Binding ResetOpenHotkeyCommand}"
                                    ToolTip="Reset to Ctrl+Shift+V" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Text="Window opacity" />
                        <TextBlock Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="Adjust opacity from the slider on the main Clipt title bar to avoid conflicting controls." />

                        <Separator Margin="0,20,0,18" />

                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Text="Showroom" />
                        <TextBlock Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Text="Adds curated sample clips for screenshots and testing. Existing items are not affected." />
                        <Button Content="Load demo content"
                                HorizontalAlignment="Left"
                                MinWidth="160"
                                Padding="16,8"
                                Command="{Binding LoadDemoContentCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,10,0"
                    MinWidth="92"
                    Content="Save"
                    Command="{Binding SaveCommand}" />
            <Button MinWidth="92"
                    Content="Cancel"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>

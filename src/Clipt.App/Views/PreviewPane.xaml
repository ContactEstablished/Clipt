<UserControl x:Class="Clipt.App.Views.PreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Clipt.App.Controls"
             xmlns:converters="clr-namespace:Clipt.App.Converters">
    <UserControl.Resources>
        <converters:ContentTypeLabelConverter x:Key="ContentTypeLabelConverter" />
        <converters:ContentTypeVisibilityConverter x:Key="ContentTypeVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:HexColorBrushConverter x:Key="HexColorBrushConverter" />
    </UserControl.Resources>

    <Grid Margin="18,16,18,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <Border Padding="10,5"
                    Background="{DynamicResource Clipt.Brush.AccentSoft}"
                    BorderBrush="{DynamicResource Clipt.Brush.Accent}"
                    BorderThickness="1"
                    CornerRadius="999">
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Clipt.Brush.Accent}"
                           Text="{Binding ContentType, Converter={StaticResource ContentTypeLabelConverter}}" />
            </Border>
            <TextBlock Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                       Text="{Binding SourceAppName}" />
            <TextBlock Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource Clipt.Brush.Accent}"
                       Text="Pinned"
                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}" />
        </DockPanel>

        <ItemsControl Grid.Row="1"
                      Margin="0,12,0,0"
                      ItemsSource="{Binding AvailableFormats}"
                      Visibility="{Binding HasAvailableFormats, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,6,6"
                            Padding="7,4"
                            Background="{DynamicResource Clipt.Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Clipt.Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource Clipt.Brush.TextSecondary}">
                            <Run Text="{Binding DisplayName, Mode=OneTime}" />
                            <Run Text=" · " Foreground="{DynamicResource Clipt.Brush.TextMuted}" />
                            <Run Text="{Binding SizeLabel, Mode=OneTime}" Foreground="{DynamicResource Clipt.Brush.TextMuted}" />
                        </TextBlock>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2" Margin="0,16,0,16">
            <controls:MarkdownPreviewControl Markdown="{Binding Content}"
                                             Visibility="{Binding ContentType, Converter={StaticResource ContentTypeVisibilityConverter}, ConverterParameter=Markdown}" />

            <controls:CodePreviewControl Text="{Binding Content, Mode=OneWay}"
                                         SyntaxLanguage="{Binding Language, Mode=OneWay}"
                                         Visibility="{Binding ContentType, Converter={StaticResource ContentTypeVisibilityConverter}, ConverterParameter=Code|Json}" />

            <controls:ImagePreviewControl ImageUri="{Binding ImageUri}"
                                          Visibility="{Binding ContentType, Converter={StaticResource ContentTypeVisibilityConverter}, ConverterParameter=Image}" />

            <Border Background="#101014"
                    BorderBrush="{DynamicResource Clipt.Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Visibility="{Binding ContentType, Converter={StaticResource ContentTypeVisibilityConverter}, ConverterParameter=Color}">
                <StackPanel>
                    <Border Width="160"
                            Height="96"
                            HorizontalAlignment="Left"
                            Background="{Binding Content, Converter={StaticResource HexColorBrushConverter}}"
                            BorderBrush="{DynamicResource Clipt.Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8" />
                    <TextBlock Margin="0,18,0,0"
                               FontFamily="{StaticResource Clipt.Font.Mono}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="{Binding Content, Mode=OneWay}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                               Text="{Binding PreviewText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Background="#101014"
                    BorderBrush="{DynamicResource Clipt.Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Visibility="{Binding ContentType, Converter={StaticResource ContentTypeVisibilityConverter}, ConverterParameter=Text|Url}">
                <TextBox Background="Transparent"
                         BorderThickness="0"
                         FontFamily="{StaticResource Clipt.Font.Ui}"
                         FontSize="15"
                         Foreground="{DynamicResource Clipt.Brush.Text}"
                         IsReadOnly="True"
                         Text="{Binding Content, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Border>

            <Border Background="#101014"
                    BorderBrush="{DynamicResource Clipt.Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Visibility="{Binding HasFilePathPreviews, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,12"
                               FontSize="12"
                               Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                               Text="{Binding FilePathSummary}" />

                    <ItemsControl ItemsSource="{Binding FilePathPreviews}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="12,10"
                                        Background="{DynamicResource Clipt.Brush.Surface}"
                                        CornerRadius="7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource Clipt.Brush.SurfaceAlt}"
                                                CornerRadius="4">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Clipt.Brush.TextSecondary}"
                                                       Text="{Binding KindGlyph}" />
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Clipt.Brush.Text}"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                                                       Text="{Binding ParentPath}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right">
                                            <Border Padding="5,2"
                                                    HorizontalAlignment="Right"
                                                    Background="{DynamicResource Clipt.Brush.AccentSoft}"
                                                    CornerRadius="3">
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Clipt.Brush.Accent}"
                                                           Text="{Binding ExtensionLabel}" />
                                            </Border>
                                            <TextBlock Margin="0,4,0,0"
                                                       HorizontalAlignment="Right"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Clipt.Brush.TextMuted}"
                                                       Text="{Binding StatusLabel}" />
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Width="28"
                                                Height="28"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Copy path"
                                                Command="{Binding CopyPathCommand}">
                                            <Button.Resources>
                                                <Style x:Key="CopyPathIconStyle" TargetType="Path">
                                                    <Setter Property="Stroke" Value="{DynamicResource Clipt.Brush.TextMuted}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Stroke" Value="{DynamicResource Clipt.Brush.Accent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                            <Path Width="14"
                                                  Height="14"
                                                  Data="M8 3h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z M14 3V1.5A1.5 1.5 0 0 0 12.5 0h-8A1.5 1.5 0 0 0 3 1.5v8A1.5 1.5 0 0 0 4.5 11H6"
                                                  StrokeLineJoin="Round"
                                                  StrokeThickness="1.8"
                                                  Stretch="Uniform"
                                                  Style="{StaticResource CopyPathIconStyle}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" LastChildFill="False">
            <Button Margin="0,0,8,0" Content="Paste · Enter" />
            <Button Content="Copy · Shift+Enter" />
        </DockPanel>
    </Grid>
</UserControl>

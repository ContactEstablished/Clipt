<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Clipt.Color.Background">#0E0E10</Color>
    <Color x:Key="Clipt.Color.Surface">#18181B</Color>
    <Color x:Key="Clipt.Color.SurfaceAlt">#202024</Color>
    <Color x:Key="Clipt.Color.Border">#2A2A30</Color>
    <Color x:Key="Clipt.Color.Text">#F4F4F5</Color>
    <Color x:Key="Clipt.Color.TextSecondary">#A1A1AA</Color>
    <Color x:Key="Clipt.Color.TextMuted">#71717A</Color>
    <Color x:Key="Clipt.Color.Accent">#14B8A6</Color>
    <Color x:Key="Clipt.Color.AccentSoft">#262F31</Color>
    <Color x:Key="Clipt.Color.Highlight">#335F5B</Color>

    <SolidColorBrush x:Key="Clipt.Brush.Background" Color="{StaticResource Clipt.Color.Background}" />
    <SolidColorBrush x:Key="Clipt.Brush.Surface" Color="{StaticResource Clipt.Color.Surface}" />
    <SolidColorBrush x:Key="Clipt.Brush.SurfaceAlt" Color="{StaticResource Clipt.Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Clipt.Brush.Border" Color="{StaticResource Clipt.Color.Border}" />
    <SolidColorBrush x:Key="Clipt.Brush.Text" Color="{StaticResource Clipt.Color.Text}" />
    <SolidColorBrush x:Key="Clipt.Brush.TextSecondary" Color="{StaticResource Clipt.Color.TextSecondary}" />
    <SolidColorBrush x:Key="Clipt.Brush.TextMuted" Color="{StaticResource Clipt.Color.TextMuted}" />
    <SolidColorBrush x:Key="Clipt.Brush.Accent" Color="{StaticResource Clipt.Color.Accent}" />
    <SolidColorBrush x:Key="Clipt.Brush.AccentSoft" Color="{StaticResource Clipt.Color.AccentSoft}" />
    <SolidColorBrush x:Key="Clipt.Brush.Highlight" Color="{StaticResource Clipt.Color.Highlight}" />

    <LinearGradientBrush x:Key="Clipt.Brush.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E60E0E10" Offset="0" />
        <GradientStop Color="#F4141417" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>

<UserControl x:Class="Clipt.App.Controls.HotkeyCaptureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinHeight="42"
             Focusable="True"
             Cursor="Hand"
             FocusVisualStyle="{x:Null}"
             MouseLeftButtonDown="OnMouseLeftButtonDown"
             PreviewKeyDown="OnPreviewKeyDown"
             PreviewKeyUp="OnPreviewKeyUp"
             LostKeyboardFocus="OnLostKeyboardFocus">
    <Border x:Name="Chrome"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,8"
            SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="{x:Type Border}">
                <Setter Property="Background" Value="#1C1C20" />
                <Setter Property="BorderBrush" Value="{DynamicResource Clipt.Brush.Border}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#222227" />
                        <Setter Property="BorderBrush" Value="#35353B" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=Root}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource Clipt.Brush.Accent}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsCapturing, ElementName=Root}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Clipt.Brush.AccentSoft}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="GestureText"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource Clipt.Font.Mono}"
                       FontSize="13"
                       Text="{Binding DisplayText, ElementName=Root}">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.Text}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCapturing, ElementName=Root}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.Accent}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="8,3"
                    Background="{DynamicResource Clipt.Brush.AccentSoft}"
                    BorderBrush="{DynamicResource Clipt.Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="999">
                <TextBlock x:Name="StateText"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="{Binding StateLabel, ElementName=Root}">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.TextSecondary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCapturing, ElementName=Root}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Clipt.Brush.Accent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</UserControl>

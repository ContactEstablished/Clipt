<UserControl x:Class="Clipt.App.Controls.ImagePreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#101014"
            BorderBrush="{DynamicResource Clipt.Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <Image Source="{Binding ImageUri, RelativeSource={RelativeSource AncestorType=UserControl}}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality" />
    </Border>
</UserControl>

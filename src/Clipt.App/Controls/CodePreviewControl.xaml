<UserControl x:Class="Clipt.App.Controls.CodePreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Border Background="#101014"
            BorderBrush="{DynamicResource Clipt.Brush.Border}"
            BorderThickness="1"
            CornerRadius="8">
        <avalonEdit:TextEditor x:Name="Editor"
                               Background="#101014"
                               Foreground="{DynamicResource Clipt.Brush.Text}"
                               FontFamily="{StaticResource Clipt.Font.Mono}"
                               FontSize="13"
                               IsReadOnly="True"
                               Padding="14"
                               ShowLineNumbers="True"
                               WordWrap="False" />
    </Border>
</UserControl>
